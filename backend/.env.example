PORT=3000
NODE_ENV=production

# MongoDB Atlas — use the direct URI (not mongodb+srv://) if TXT DNS fails
MONGO_URI=mongodb://USER:PASSWORD@HOST1:27017,HOST2:27017,HOST3:27017/observator?replicaSet=REPLICA_SET&authSource=admin&tls=true

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_STRING

# API Base URL (no trailing slash)
API_BASE_URL=https://observator-backend.onrender.com

# Nodemailer — Gmail SMTP with App Password
EMAIL_MAILER=your-gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=Observator <your-gmail@gmail.com>

# Mobile static API key — hardcode this in NEP-LINK and MET-LINK apps
# Generate with: node -e "console.log('obs_mob_' + require('crypto').randomBytes(32).toString('hex'))"
MOBILE_API_KEY=obs_mob_CHANGE_ME
MOBILE_ORG_ID=MONGODB_OBJECTID_OF_YOUR_ORG
